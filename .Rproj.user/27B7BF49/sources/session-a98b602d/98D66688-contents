#Make a list of the paths of files so that R can import with read_csv
file_list <- list.files(path = "./chlamy_data",
                        full.names = TRUE, ignore.case = TRUE, pattern = "QMF.*xlsx$")


map <- read_csv("chlamy_map.csv", col_types = cols(
    Date = col_date(format = "%m/%d/%Y"),
    open_time1 = col_time(format = "%H:%M"), 
    open_time2 = col_time(format = "%H:%M"),
    avg_open_time = col_time(format = "%H:%M"))) |>
  rowwise() |>
  mutate(Treatment = str_to_upper(treatment),
         avg_open_time = as.POSIXct(paste(Date, avg_open_time), format = "%Y-%m-%d %H:%M", tz = "UTC"),
         open_time2 = as.POSIXct(paste(Date, open_time2), format = "%Y-%m-%d %H:%M", tz = "UTC"),
         open_time1 = as.POSIXct(paste(Date, open_time1), format = "%Y-%m-%d %H:%M", tz = "UTC"),
         Date = format(Date,"%m-%d-%Y")) |>
  filter(!is.na(Treatment))


#Import plate data with annotations
raw_data <- file_list |>
  map_df(~read_data(.))

#Import fluoroprobe data from mussel feeding exp
fp_data <-  raw_data |>
  rename("blugrn" = Bluegreen,
         "time" = `Date/Time`,
         "grn" = `Green Algae`,
         "total_chla" = `Total conc.`) |>
  mutate(dd = lubridate::decimal_date(time),
         Date = format(time,"%m-%d-%Y"),
         Treatment = str_remove_all(Treatment, ' '),
         Treatment = str_to_upper(Treatment)) |>
  pivot_longer(cols = c(blugrn,grn,total_chla), 
               names_to = 'category', values_to = 'chla') #This step will help later in rate calculations.

fp_summary <- fp_data %>%
  group_by(Treatment, Timepoint, Date, category) %>%
    #Average the plate reader technical replicates. Using across() saves us from doing the renaming ourselves
  dplyr::summarise(across(c(chla, time), list(avg = mean, sd = sd), .names = "{.fn}_{.col}")) |>
  select(-c(sd_time)) |>
  ungroup() |>
  mutate(rep = case_when(str_detect(Treatment, "Q") ~ str_extract(Treatment, "Q\\d"),
                         T ~ "C"))


treatment <- filter(fp_summary, rep != "C")

mussel_open_time <- map |>
  select(strain,Treatment,Date,open_time1,open_time2,volume,M1, M2)
                     
full_data <- fp_summary |>
  group_by(Treatment,category, Date) |>
  full_join(mussel_open_time, by = c("Date", 'Treatment')) |>
  mutate(
    avg_time = ifelse(Timepoint == 'TF', avg_time[avg_time == max(avg_time[avg_time != max(avg_time)])], avg_time),
    begin = min(avg_time),
    closed_interval1 = begin %--% open_time1,
    closed_interval2 = begin %--% open_time2,
    read_interval = begin %--% avg_time,
    hours = as.numeric(as.duration((read_interval) / dhours(1))),
    open_time1 = as.numeric(as.duration((closed_interval1) / dhours(1))),
    open_time2 = as.numeric(as.duration((closed_interval2) / dhours(1))),
    #Get time between each read
    source = case_when(Timepoint == "TF" ~ "Mixed", #Water column is during the experiment while mixed is the final reading.
                       T ~ "Water Column")
  ) |>
  select(-c(begin, read_interval, closed_interval1, closed_interval2))
 
split_df <- split(full_data, f = list(full_data$strain),drop = T,sep = '_')

plot_fp_data(split_df)
