  geom_errorbar(aes(ymin = avg_IR - se_IR, ymax = avg_IR + se_IR), width = 0.2) +
  theme_pubclean(base_size = 14) +
  geom_text(aes(label = Letters, x = Treatment, y = avg_IR + se_IR + 0.01), 
            check_overlap = T) + 
  coord_cartesian(ylim = c(0,0.15))+
  rotate_x_text(angle = 60)

#Clearance rate on microcystis
anova_CR <- aov(CR ~ strain*State, data = PCC_strains)
tukey <- TukeyHSD(anova_CR)
tukey_CR <- multcompLetters4(anova_CR, tukey)
cld_CR <- as.data.frame.list(tukey_CR$`strain:State`) |>
  rownames_to_column("strain") |>
  separate_wider_delim(strain, ':', names = c('strain','State')) |>
  unite(col = Treatment, State:strain, sep = ' ')

CR_barplot_PCC <- ggplot(data = PCC_plotting_data |> left_join(cld_CR), 
       aes(x = Treatment, y = avg_CR)) +
  ylab("Capture Rate (μg/mg AFDW/h)") +
  geom_col(width = .7 , color = 'black', fill = NA) +
  geom_errorbar(aes(ymin = avg_CR - se_CR, ymax = avg_CR + se_CR), width = 0.2) +
  theme_pubclean(base_size = 14) +
  geom_text(aes(label = Letters, x = Treatment, y = avg_CR + se_CR + 0.01), 
            check_overlap = T) + 
  coord_cartesian(ylim = c(0,0.15))+
  rotate_x_text(angle = 60)

PCC_barplots <- ggarrange(common.legend = T, legend = "right",
                          nrow = 2,ncol = 2, labels = "AUTO", 
                          FR_barplot_PCC, FI_barplot_PCC, CR_barplot_PCC, IR_barplot_PCC)

ggsave('../../figures/mf_results/feeding_rates/PCC_feeding_barplt.png',PCC_barplots,width = 400, height = 400, units = "mm", dpi = 450 )

#Testing Axenic vs Xenic
cld_avx <- as.data.frame.list(tukey_FR$`State`) |>
