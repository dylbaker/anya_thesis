(From Vanderploeg 2001) C is the mean Chl a concentration in the water column at the end of the experiment in control containers, Z is the Chl a concentration in the water column of an experimental container at the end of the experiment, V is the volume of water in the container during the experiment, n is the number of mussels, and t is the duration of the experiment.

```{r Mussel AFDW}
mussel_info <- read_csv("./all_mussel_DW.csv") |>
  mutate(GDW = gut_dry_mass - capsule_mass,
         PAW = gut_pa_mass - capsule_mass,
         AFDW = GDW - PAW,
         combust_eff = AFDW/GDW)

#Linear regression of AFDW and GDW of mussel tissue and shell-length
AFDW_lm <- rlm(AFDW ~ length, data = mussel_info) #Robust linear model, log transformed

predict_M1 <- predict(AFDW_lm, newdata = data.frame(length = full_data$M1))
predict_M2 <- predict(AFDW_lm, newdata = data.frame(length = full_data$M2))
full_data$M1_AFDW <- predict_M1
full_data$M2_AFDW <- predict_M2

#Check for normality, non-sig p-value indicates normality
shapiro_test(mussel_info$AFDW) # p > 0.05

#Check residuals vs fitted plot
plot(lm(AFDW ~ length, data = mussel_info))

AFDW_plot <- ggplot(mussel_info, aes(x = length, y = AFDW)) +
  geom_point(aes(group = )) +
  geom_smooth(aes(group = ), method = "rlm",
              formula = y~x, level = 0.95, alpha = .15) +
  scale_color_manual(values =  c("1" = 'royalblue1'),
                     ""
                    )+
  labs(y = "Ash-Free Dry Weight (mg)",
       x = "Mussel Shell Length (mm)") +
  stat_regline_equation(label.y = c(19,18)) +
  stat_cor(method = "pearson",
    aes(label = paste(after_stat(rr.label), after_stat(p.label), sep = "~`,`~"))) + 
  theme_pubr(base_size = 14)

treatment_data <- full_data |>
  dplyr::mutate(V = 1500,
         VFWC = case_when(Timepoint == 'T0' ~ 0,
                          Timepoint == 'T1' ~ 25,
                          Timepoint == 'T2' ~ 50,
                          Timepoint == 'T3' ~ 75,
                          Timepoint == 'T4' ~ 100,
                          Timepoint == 'T5' ~ 125,
                          Timepoint == 'T6' ~ 150,
                          T ~ NA),
         VFWC = ifelse(is.na(VFWC), VFWC[avg_time == max(avg_time[avg_time != max(avg_time)])] + 25, VFWC),
         VFM = V - VFWC) |>
  dplyr::mutate(
         total_AFDW = rowSums(pick(M1_AFDW, M2_AFDW), na.rm = T),
         total_C = total_AFDW * 0.524,
         percent_C = total_C/total_AFDW)

#Calculations for control data to get final water column and mixed measurements to correct for settling and death in mussel grazer experiments 
control_data <- filter(treatment_data, rep == 'C') |>
  select(Treatment,Timepoint, Date, strain, category, avg_chla, avg_time, V, VFWC, VFM, hours) |>
  filter(category != "blugrn") |>
  group_by(strain, Date, category) |>
  mutate(C0 = avg_chla[Timepoint == "T0"], #Initial control measurement time T0.
         CFWC = avg_chla[Timepoint == "T5"], #Final control measurement before mixing
         CFM = avg_chla[Timepoint == "TF"]) |>#Final control measurement mixed
  filter(VFM == min(VFM)) |> #Filter out unneeded rows
  dplyr::mutate(CFMx = (VFM/V)*CFM+(VFWC/V)*CFWC) |> #Control final corrected for sample volume removed
  ungroup() |>
  dplyr::select(-c(Timepoint,Treatment,avg_chla,V,VFM,VFWC,hours)) |>
  unique()

#Calculations for experimental data to get final water column and mixed measurements
exp_data <-  filter(treatment_data, rep != 'C') |>
  select(Treatment,Timepoint, Date, strain,open_time1, open_time2,total_AFDW, category, avg_chla, avg_time, V, VFWC, VFM, hours) |>
  group_by(Treatment, strain, Date, category) |>
  mutate(Z0 = avg_chla[Timepoint == "T0"], #Initial control measurement time T0.
         ZFWC = avg_chla[Timepoint == "T5"], #Final control measurement before mixing
         ZFM = avg_chla[Timepoint == "TF"]) |> #Final control measurement mixed
  filter(VFM == min(VFM)) |> #Filter out unneeded rows
  mutate(ZFMx = (VFM/V)*ZFM+(VFWC/V)*ZFWC, #Control final corrected for sample volume removed
         ZavWC = (Z0-ZFWC)/log(Z0/ZFWC), #Average concentration chla in the water column
         ZavM = (Z0-ZFM)/log(Z0/ZFM)) |> #Control final corrected for sample volume removed
  ungroup() |>
  select(-c(Timepoint, avg_chla, avg_time)) |>
  unique()

#Combine the experimental and control data to caluclate feeding and clearance rates
combined_data <-merge(exp_data, control_data,by= c('strain', 'Date', 'category')) |>
  mutate(across(everything(), \(x) replace_na(x, 0))) |>
  #Merge control data with exp data.
  mutate(closed_duration = (open_time1 + open_time2) /2,
        FR = (V/(total_AFDW*(hours-closed_duration)))*(log(Z0)-log(ZFWC)+log(CFWC)-log(C0)), #Clearance rate on amount removed, includes correction
         FI = (V/(total_AFDW*(hours-closed_duration)))*(log(Z0)-log(ZFMx)-log(C0)+log(CFMx)), #Clearance rate on amount ingested, includes correction
         CR = ZavWC*FR/1000,#Capture rate
         IR = ZavM*FI/1000, #Ingestion rate
         ) 

#Change all Inf, NA, NaN values to 0, as these represent Treatments where either bluegreen or green were not present. E.g. C. oblonga controls
combined_data[sapply(combined_data, is.infinite)] <- NA
combined_data[sapply(combined_data, is.nan)] <- NA

long_data <- combined_data |>
  select(strain, Date, Treatment, category,
          FR, #Clearance rates on amount removed mL/mg/h
          FI, #Clearance rates on amount ingested mL/mg/h
          CR, #Capture rate or "search" rate
          IR) |> #Ingestion rate
  pivot_longer(
    cols = c(
          FR, #Clearance rates on amount removed mL/mg/h
          FI, #Clearance rates on amount ingested mL/mg/h
          CR, #Capture rate or "search" rate
          IR) #Ingestion rate
    ,
    names_to = c("metric"),
    values_to = "rate"
  ) |>
  filter(rate > 0) |>
  group_by(strain, metric, Date, category,Treatment) |>
  mutate(metric = factor(metric, levels = c('FR','FI','CR','IR'))) |>
  dplyr::summarise(across(rate, list(avg = mean, sd = sd, se= ~sd(.)/sqrt(n())), .names = "{.fn}_{.col}"))
