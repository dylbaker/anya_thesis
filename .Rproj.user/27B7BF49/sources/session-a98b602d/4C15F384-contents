```{r Clearance and Ingestion Rates}
feeding_data <- data_summary |>
  mutate(V = Volume *1000,
         VFWC = case_when(Timepoint == 'T0' ~ 1.6, #Volume removed for samples, in mL (increases with every timepoint).
                          Timepoint == 'T1' ~ 3.2,
                          Timepoint == 'T2' ~ 4.8,
                          Timepoint == 'T3' ~ 6.4,
                          T ~ NA),
         VFM = V - VFWC,
         M1AFDW = -17.1098  + 1.3387 * M1, #regression line from model
         M2AFDW = -17.1098  + 1.3387 * M2,
         total_AFDW = M1AFDW + M2AFDW,
         total_C = total_AFDW * 0.524,
         percent_C = total_C/total_AFDW) |>
  ungroup()

control_data <- filter(feeding_data, str_detect(treatment, "NQC")) |>
  select(c(well_ID,category,value,Timepoint,treatment, concentration,V,VFM,VFWC)) |>
  group_by(category,well_ID) |>
  mutate(C0 = value[Timepoint == "T0"], #Initial control measurement time T0.
         CFWC = value[Timepoint == "T3"], #Final control measurement before mixing
         CFM = value[Timepoint == "TF"]) |>#Final control measurement mixed
  filter(VFM == 1493.6) |> #Filter out unneeded rows
  mutate(CFMx = (VFM/V)*CFM+(VFWC/V)*CFWC) |> #Control final corrected for sample volume removed
  ungroup() |>
  select(-c(Timepoint,V,VFM,VFWC,treatment,well_ID))

exp_data <- filter(feeding_data, !str_detect(treatment, "NQC")) |>
  select(well_ID,category,value,Timepoint,treatment, hours,concentration,total_AFDW,V, VFM, VFWC) |>
  group_by(treatment, category) |>
  mutate(Z0 = value[Timepoint == "T0"], #Initial measurement time T0.
         ZFWC = value[Timepoint == "T3"], #Final control measurement before mixing
         ZFM = value[Timepoint == "TF"]) |> #Final control measurement mixed
  filter(VFM == 1493.6) |> #Filter out unneeded rows
  mutate(ZFMx = (VFM/V)*ZFM+(VFWC/V)*ZFWC, #Control final corrected for sample volume removed
         ZavWC = (Z0-ZFWC)/log(Z0/ZFWC), #Average concentration chla in the water column
         ZavM = (Z0-ZFM)/log(Z0/ZFM)) |> #Average concentration of bluegreens after mixing
  ungroup() |>
  select(-c(Timepoint, value,well_ID))

combined_data <- merge(exp_data, control_data,by= c('concentration', 'category'),all.x = TRUE) |> #Merge control data with exp data.
  group_by(category) |>
  mutate(FR = (V/(total_AFDW*hours))*(log(Z0)-log(ZFWC)+log(CFWC)-log(C0)), #Clearance rate on amount removed, includes correction
         FI = (V/(total_AFDW*hours))*(log(Z0)-log(ZFMx)-log(C0)+log(CFMx)), #Clearance rate on amount ingested, includes correction
         CR = ZavWC*FR/1000,#Capture rate
         IR = ZavM*FI/1000, #Ingestion rate
         ) |>
  ungroup()

#Change all Inf, NA, NaN values to 0, as these represent treatments where either bluegreen or green were not present. E.g. C. oblonga controls
combined_data[sapply(combined_data, is.infinite)] <- NA
combined_data[sapply(combined_data, is.nan)] <- NA

long_data <- combined_data |>
  select(treatment, category,concentration,
          FR, #Clearance rates on amount removed mL/mg/h
          FI, #Clearance rates on amount ingested mL/mg/h
          CR, #Capture rate or "search" rate
          IR) |> #Ingestion rate
  pivot_longer(
    cols = c(
          FR, #Clearance rates on amount removed mL/mg/h
          FI, #Clearance rates on amount ingested mL/mg/h
          CR, #Capture rate or "search" rate
          IR) #Ingestion rate
    ,
    names_to = c("metric"),
    values_to = "rate"
  ) |>
  filter(!is.na(rate)) |>
  group_by(metric, category,concentration) |>
  mutate(metric = factor(metric, levels = c('FI','FR','CR','IR'))) |>
  dplyr::summarise(across(rate, list(avg = mean, sd = sd), .names = "{.fn}_{.col}"))

#New facet label names for metric variable
metric.labs <- c(`FR` = "Clearance Rate\n(on amount removed)",
                    `FI` = "Clearance Rate\n(on amount ingested)",
                    `CR`= "Capture Rate",
                    `IR` = "Ingestion Rate")
#First look at ingestion rate, clearance rate,
clearance_plots <- ggplot(data = filter(long_data, metric %in% c("FI","FR")) |> arrange(concentration), 
       aes(x = concentration, y = avg_rate, color = category)) +
  ylab("Rate (mL/mg AFDW/h)") +
  ggtitle("Quagga Mussel Grazing on Different Concentrations of Chlamy") +
  geom_col(width = .5 , fill = NA, position = position_dodge(width = 0.55)) +
  facet_wrap(~metric, labeller = as_labeller(metric.labs)) +
  #scale_y_continuous(breaks = c(0,10,20,30,40)) +
  geom_errorbar(aes(ymin = avg_rate - sd_rate, ymax = avg_rate + sd_rate), width = 0.2, position = position_dodge(width = 0.55)) +
  scale_color_manual("", values = c("chlA1" = "cadetblue2",
                                               "chlA2" = "coral")) +
  theme_pubclean(base_size = 14) +
  #geom_text(aes(label = Letters, x = Culture, y = avg_IRB + sd_IRB + 0.01), check_overlap = T) +
  rotate_x_text(angle = 60)

capture_plots <- ggplot(data = filter(long_data, metric %in% c("CR","IR")) |> arrange(concentration), 
       aes(x = concentration, y = avg_rate, color = category)) +
  ylab("Rate (μg/mg AFDW/h)") +
  #geom_boxplot(fill = NA, position = position_dodge(width = 0.55), width = .5)
  geom_col(width = .5 , fill = NA, position = position_dodge(width = 0.55)) +
  facet_wrap(~metric, labeller = as_labeller(metric.labs)) +
  geom_errorbar(aes(ymin = avg_rate - sd_rate, ymax = avg_rate + sd_rate), width = 0.2, position = position_dodge(width = 0.55)) +
  scale_color_manual("", values = c("chlA1" = "cadetblue2",
                                               "chlA2" = "coral")) +
  theme_pubclean(base_size = 14) +
  #geom_text(aes(label = Letters, x = Culture, y = avg_IRB + sd_IRB + 0.01), check_overlap = T) +
  rotate_x_text(angle = 60)

combined_barplots <- ggarrange(common.legend = T, legend = "right", nrow = 2, labels = "AUTO", clearance_plots, capture_plots)

ggsave('./all_rates_barplt.png',combined_barplots,
       width = 250, height = 200, 
       units = "mm", dpi = 450 )

#Calculate mean, sd, se in prep for plotting.
plotting_data <- filter(combined_data,!is.na(CR)) |>
  group_by(Date,category) |>
    #Average the clearance and ingestion rates for each fraction. Using across() saves us from doing the renaming ourselves
  summarise(across(c(CR,IR,FR,FI),list(avg = mean,sd = sd , se = ~ (sd(.x)/sqrt(n()))), .names = "{.fn}_{.col}")) |>
  ungroup()
