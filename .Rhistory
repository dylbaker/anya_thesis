#Group data by metric and category, filter out total chla
summary_data <- combined_data |>
select(strain, Date, treatment, category,strain,
FR, #Clearance rates on amount removed mL/mg/h
FI, #Clearance rates on amount ingested mL/mg/h
CR, #Capture rate or "search" rate
IR) |> #Ingestion rate
pivot_longer(
cols = c(
FR, #Clearance rates on amount removed mL/mg/h
FI, #Clearance rates on amount ingested mL/mg/h
CR, #Capture rate or "search" rate
IR), #Ingestion rate
names_to = c("metric"),
values_to = "rate"
) |>
filter(!is.na(rate)) |>
group_by(metric,category, strain) |>
mutate(metric = factor(metric, levels = c('FR','FI','CR','IR'))) |>
dplyr::summarise(across(rate, list(avg = mean, sd = sd), .names = "{.fn}_{.col}"))
View(summary_data)
#First look at ingestion rate, clearance rate,
clearance_summary_plots <- ggplot(data = filter(summary_data, metric %in% c("FR","FI"), category == "grn"),
aes(x = strain, y = avg_rate, color = strain)) +
ylab("Clearance Rate (mL/mg AFDW/h)") +
xlab("Treatment") +
geom_col(width = .7 , fill = NA, position = position_dodge(width = 0.75)) +
facet_wrap(~metric, labeller = as_labeller(metric.labs), ncol = 2) +
#scale_y_continuous(breaks = c(0,20,40,60,80)) +
geom_errorbar(aes(ymin = avg_rate - sd_rate, ymax = avg_rate + sd_rate),
width = 0.3,
position = position_dodge(width = 0.75)) +
scale_color_manual("", values = c("mixed" = "orange2",
"chlamy" = "chartreuse4"),
labels = c("mixed" = "Chlamydomonas in Mixed Treatment",
"chlamy" = "Chlamydomonas alone")) +
theme_pubclean(base_size = 12) +
#geom_text(aes(label = Letters, x = strain, y = avg_IRB + sd_IRB + 0.01), check_overlap = T) +
rotate_x_text(angle = 60)
clearance_summary_plots
View(summary_data)
View(combined_data)
