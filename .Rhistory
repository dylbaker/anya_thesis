#Feeding on microcystis first look barplots.
blugrn_clearance_plots <- ggplot(data = filter(long_data, metric %in% c("FR","FI"),! strain %in% c("C"), !category == 'total_chla') |> arrange(strain),
aes(x = strain, y = avg_rate, color = category)) +
ylab("Rate (mL/mg AFDW/h)") +
xlab("*Microcystis aeruginosa* Strain") +
geom_col(width = .7 , fill = NA, position = position_dodge(width = 0.75)) +
facet_wrap(~metric, labeller = as_labeller(metric.labs), nrow =2) +
scale_y_continuous(breaks = c(0,20,40,60,80)) +
geom_errorbar(aes(ymin = avg_rate - sd_rate, ymax = avg_rate + sd_rate), width = 0.3, position = position_dodge(width = 0.75)) +
scale_color_manual("", values = c("blugrn" = "#3399FF",
"grn" = "orange2"),
labels = c("blugrn" = "*M. aeruginosa*",
"grn" = "*C. oblonga*")) +
theme_pubclean(base_size = 12) +
theme(axis.title.x = ggtext::element_markdown(),
legend.position = 'bottom',
legend.text = ggtext::element_markdown()) +
rotate_x_text(angle = 60)
