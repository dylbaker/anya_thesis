geom_errorbar(aes(ymin = avg_rate - sd_rate, ymax = avg_rate + sd_rate), width = 0.3, position = position_dodge(width = 0.75)) +
scale_color_manual("", values = c("blugrn" = "#3399FF",
"grn" = "orange2",
'total_chla' = 'gray70'),
labels = c("blugrn" = "Cyanobacteria",
"grn" = "Green Algae"),
'total_chla' = 'Total Chlorophyll-A') +
theme_pubclean(base_size = 12) +
theme(axis.title.x = ggtext::element_markdown(),
legend.position = 'bottom',
legend.text = ggtext::element_markdown()) +
rotate_x_text(angle = 60)
